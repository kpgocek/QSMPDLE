@page "/changelog"
@using MudBlazor

<WebPage>
    <h2>Changelog</h2>

    <p class="info">
        Last updated: June 2026
    </p>

    <MudAlert Severity="Severity.Success" Dense="true" Variant="Variant.Outlined" Class="mb-6">
        Future updates may include more characters, quality upgrades, and user-requested features.
    </MudAlert>

    <section class="mb-5">
        <h3>1.1 | Analytics & Telemetry Update</h3>

        <ul>
            <li>Anonymous gameplay statistics</li>
            <li>Added MissaSinfonia to the roster</li>
            <li>Improved sharing experience</li>
            <li>Better menu and navigation</li>
            <li>Updated instructions</li>
            <li>Character data fixes</li>
            <li>Added sitemap support</li>
            <li>Mobile improvements</li>
            <li>Stability and performance fixes</li>
        </ul>

    </section>

    <section class="mb-5">
        <h3>1.0 | Initial Release</h3>

        <ul>
            <li>Daily Mode</li>
            <li>Practice Mode</li>
            <li>Portrait reveal system</li>
            <li>Attribute comparison clues</li>
            <li>Streak tracking</li>
            <li>Result sharing</li>
            <li>Mobile-friendly layout</li>
            <li>Instructions page</li>
            <li>Privacy Policy</li>
            <li>About page</li>
        </ul>
        </section>
</WebPage>
