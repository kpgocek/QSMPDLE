@page "/changelog"
@using MudBlazor

<WebPage>
    <h2>Changelog</h2>

    <p class="info">
        Last updated: June 2026 (v 1.2)
    </p>

    <MudAlert Severity="Severity.Success" Dense="true" Variant="Variant.Outlined" Class="mb-6">
        Future updates may include more characters, quality upgrades, and user-requested features.
    </MudAlert>

    <section class="mb-5">
        <h3>1.2 | Performance & UI Refresh</h3>

        <ul>
            <li>Fixed an issue where guesses sometimes appeared only after refreshing the page</li>
            <li>Improved game state synchronization and reliability</li>
            <li>Prevented duplicate statistics and telemetry entries</li>
            <li>Optimized character and lookup caching</li>
            <li>Faster portrait loading with better browser caching</li>
            <li>Removed blocking operations from UI rendering</li>
            <li>Improved responsiveness on mobile devices</li>
            <li>Modernized visual design with cleaner surfaces and subtle animations</li>
            <li>Switched entirely to locally hosted fonts and assets</li>
            <li>Updated Privacy Policy to reflect anonymous analytics collection</li>
            <li>Fixed missing comparison arrows in guess chips</li>
            <li>Numerous stability and quality-of-life improvements</li>
        </ul>
    </section>

    <section class="mb-5">
        <h3>1.1 | Analytics & Telemetry Update</h3>

        <ul>
            <li>Anonymous gameplay statistics</li>
            <li>Added MissaSinfonia to the roster</li>
            <li>Improved sharing experience</li>
            <li>Better menu and navigation</li>
            <li>Updated instructions</li>
            <li>Character data fixes</li>
            <li>Added sitemap support</li>
            <li>Mobile improvements</li>
            <li>Stability and performance fixes</li>
        </ul>

    </section>

    <section class="mb-5">
        <h3>1.0 | Initial Release</h3>

        <ul>
            <li>Daily Mode</li>
            <li>Practice Mode</li>
            <li>Portrait reveal system</li>
            <li>Attribute comparison clues</li>
            <li>Streak tracking</li>
            <li>Result sharing</li>
            <li>Mobile-friendly layout</li>
            <li>Instructions page</li>
            <li>Privacy Policy</li>
            <li>About page</li>
        </ul>
        </section>
</WebPage>
