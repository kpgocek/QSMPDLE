@page "/stats"

@using MudBlazor
@using QSMPDLE.Web.Components.UX
@using QSMPDLE.Web.Components.Statistics
@using QSMPDLE.Web.Features.Statistics.Models
@using QSMPDLE.Web.Infrastructure.LocalStorage
@using QSMPDLE.Web.Infrastructure.Persistence

@inject IPlayerStatsStore PlayerStatsStore
@inject IGameStatsStore GameStatsStore
@inject ICharacterStore CharacterStore
@inject ILogger<Stats> Logger

<PageTitle>Game Statistics - QSMPDLE</PageTitle>

<WebPage>

    <section class="mb-2">
        <h2>
            Statistics & Telemetry
        </h2>

        <p class="info">
            Some interesting information about our players
        </p>

        <MudAlert Severity="Severity.Success" Dense="true" Variant="Variant.Outlined" Class="mb-6">
            <strong>Data's incomplete.</strong> We only started collecting gameplay stats from the 1.1 release.
        </MudAlert>  
        
        <MudGrid>
            <MudItem xs="6" sm="3" Style="display:flex;">
                <StatCard Title="Players" Delay="100" Icon="@Icons.Material.Filled.PeopleAlt"
                          Value="@($"{TotalPlayers}")" />
            </MudItem>

            <MudItem xs="6" sm="3" Style="display:flex;">
                <StatCard Title="Total Games Played" Delay="200" Icon="@Icons.Material.Filled.EmojiEvents"
                          Value="@($"{TotalGamesPlayed}")" />
            </MudItem>

            <MudItem xs="6" sm="3" Style="display:flex;">
                <StatCard Title="Global Win Rate" Delay="300" Icon="@Icons.Material.Filled.LocalFireDepartment"
                          Value="@($"{GlobalWinRate:0}%")" />
            </MudItem>
        </MudGrid>

    </section>

    <section class="mb-5">
        <h3>
            Your Personal Stats
        </h3>
        
        
        <section class="mb-5">

            <MudImage Src="" />

        </section>

        <section class="mb-5">
            <h4>
                Daily Mode
            </h4>

            <MudGrid>
                <MudItem xs="6" sm="3" Style="display:flex;">
                    <StatCard Title="Played" Delay="100" Icon="@Icons.Material.Filled.SportsEsports"
                              Value="@($"{DailyGamesPlayed}")" />
                </MudItem>

                <MudItem xs="6" sm="3" Style="display:flex;">
                    <StatCard Title="Won" Delay="200" Icon="@Icons.Material.Filled.EmojiEvents"
                              Value="@($"{DailyGamesWon}")" />
                </MudItem>

                <MudItem xs="6" sm="3" Style="display:flex;">
                    <StatCard Title="Win Rate" Delay="300" Icon="@Icons.Material.Filled.LocalFireDepartment"
                              Value="@($"{DailyWinRate:0}%")" />
                </MudItem>

                <MudItem xs="6" sm="3" Style="display:flex;">
                    <StatCard Title="Best Streak" Delay="400" Icon="@Icons.Material.Filled.BarChart"
                              Value="@($"{LongestStreak}")"/>
                </MudItem>
            </MudGrid>

        </section>

        <section class="mb-5">
            <h4>
                Practice Mode
            </h4>

            <MudGrid>
                <MudItem xs="6" sm="3" Style="display:flex;">
                    <StatCard Title="Started" Delay="150" Icon="@Icons.Material.Filled.PlayArrow"
                              Value="@($"{PracticeGamesStarted}")" Comment="Yes, even skipped ones"/>
                </MudItem>

                <MudItem xs="6" sm="3" Style="display:flex;">
                    <StatCard Title="Finished" Delay="250" Icon="@Icons.Material.Filled.CheckCircle"
                              Value="@($"{PracticeGamesFinished}")" />
                </MudItem>

                <MudItem xs="6" sm="3" Style="display:flex;">
                    <StatCard Title="Won" Delay="350" Icon="@Icons.Material.Filled.WorkspacePremium"
                              Value="@($"{PracticeGamesWon}")" />
                </MudItem>

                <MudItem xs="6" sm="3" Style="display:flex;">
                    <StatCard Title="Win Rate" Delay="450" Icon="@Icons.Material.Filled.BarChart"
                              Value="@($"{AllPracticeWinRate:0}%")" Comment="@($"{FinishedPracticeWinRate:0}% of finished games")" />
                </MudItem>
            </MudGrid>
        
        </section>
    </section>

    <section class="mb-5">
        <h3>Player Activity</h3>

        <div class="mb-4">
            <MudButtonGroup Color="MudBlazor.Color.Primary" Variant="Variant.Outlined">
                <MudButton OnClick="@(() => OnTimeRangeChanged(7))"
                           Disabled="@loadingActivity"
                           Variant="@(selectedDays == 7 ? Variant.Filled : Variant.Outlined)">
                    Last 7 Days
                </MudButton>
                <MudButton OnClick="@(() => OnTimeRangeChanged(30))"
                           Disabled="@loadingActivity"
                           Variant="@(selectedDays == 30 ? Variant.Filled : Variant.Outlined)">
                    Last 30 Days
                </MudButton>
                <MudButton OnClick="@(() => OnTimeRangeChanged(0))"
                           Disabled="@loadingActivity"
                           Variant="@(selectedDays == 0 ? Variant.Filled : Variant.Outlined)">
                    All Time
                </MudButton>
            </MudButtonGroup>
        </div>

        @if (loadingActivity)
        {
            <MudProgressLinear Color="MudBlazor.Color.Primary" Indeterminate="true" Class="mb-4" />
        }
        else
        {
            <DailyActivePlayersChart ChartData="@dauData" />
            <NewVsReturningChart ChartData="@newVsReturningData" />
            <ActivityDistributionChart ChartData="@activityDistribution" />

            <MudGrid Class="mt-4">
                <MudItem xs="6" sm="4" Style="display:flex;">
                    <StatCard Title="Average Games Per Player" Delay="500" Icon="@Icons.Material.Filled.Calculate"
                              Value="@(gamesPerPlayer != null ? $"{gamesPerPlayer.Average:0.0}" : "-")" />
                </MudItem>

                <MudItem xs="6" sm="4" Style="display:flex;">
                    <StatCard Title="Median Games Per Player" Delay="600" Icon="@Icons.Material.Filled.Functions"
                              Value="@(gamesPerPlayer != null ? $"{gamesPerPlayer.Median:0}" : "-")" />
                </MudItem>

                <MudItem xs="6" sm="4" Style="display:flex;">
                    <StatCard Title="Maximum Games Per Player" Delay="700" Icon="@Icons.Material.Filled.EmojiEvents"
                              Value="@(gamesPerPlayer != null ? $"{gamesPerPlayer.Maximum}" : "-")" />
                </MudItem>
            </MudGrid>
        }
    </section>

    <section class="mb-5">
        <h3>Player Retention</h3>
        <p class="info mb-4">
            Percentage of players who returned to play exactly N days after their first game
        </p>

        @if (loadingRetention)
        {
            <MudProgressLinear Color="MudBlazor.Color.Primary" Indeterminate="true" Class="mb-4" />
        }
        else
        {
            <MudGrid>
                <MudItem xs="6" sm="3" Style="display:flex;">
                    <StatCard Title="D1 Retention" Delay="800" Icon="@Icons.Material.Filled.TrendingUp"
                              Value="@(retention != null ? $"{retention.D1Retention:0.0}%" : "-")" 
                              Comment="Returned after 1 day" />
                </MudItem>

                <MudItem xs="6" sm="3" Style="display:flex;">
                    <StatCard Title="D7 Retention" Delay="900" Icon="@Icons.Material.Filled.ShowChart"
                              Value="@(retention != null ? $"{retention.D7Retention:0.0}%" : "-")" 
                              Comment="Returned after 7 days" />
                </MudItem>

                <MudItem xs="6" sm="3" Style="display:flex;">
                    <StatCard Title="D14 Retention" Delay="1000" Icon="@Icons.Material.Filled.ShowChart"
                              Value="@(retention != null ? $"{retention.D14Retention:0.0}%" : "-")" 
                              Comment="Returned after 14 days" />
                </MudItem>

                <MudItem xs="6" sm="3" Style="display:flex;">
                    <StatCard Title="D30 Retention" Delay="1100" Icon="@Icons.Material.Filled.ShowChart"
                              Value="@(retention != null ? $"{retention.D30Retention:0.0}%" : "-")" 
                              Comment="Returned after 30 days" />
                </MudItem>
            </MudGrid>
        }
    </section>

    <section class="mb-5">
        <h3>Your Character Stats</h3>
        <p class="info mb-4">Characters you've interacted with the most</p>

        @if (loadingCharacterStats)
        {
            <MudProgressLinear Color="MudBlazor.Color.Primary" Indeterminate="true" Class="mb-4" />
        }
        else if (playerCharacterStats != null)
        {
            <MudGrid>
                <MudItem xs="12" sm="6" Style="display:flex;">
                    <StatCard Title="Most Guessed (Wrong)" Delay="200"
                              Icon="@Icons.Material.Filled.QuestionMark"
                              Value="@(playerCharacterStats.MostGuessedCharacterName ?? "-")"
                              Comment="@(playerCharacterStats.MostGuessedCount > 0 ? $"Guessed {playerCharacterStats.MostGuessedCount}× as wrong answer" : null)" />
                </MudItem>
                <MudItem xs="12" sm="6" Style="display:flex;">
                    <StatCard Title="Most Correctly Guessed" Delay="300"
                              Icon="@Icons.Material.Filled.CheckCircle"
                              Value="@(playerCharacterStats.MostCorrectlyGuessedCharacterName ?? "-")"
                              Comment="@(playerCharacterStats.MostCorrectlyGuessedCount > 0 ? $"Was the answer {playerCharacterStats.MostCorrectlyGuessedCount}× in won games" : null)" />
                </MudItem>
            </MudGrid>
        }
    </section>

    <section class="mb-5">
        <h3>Global Character Insights</h3>
        <p class="info mb-4">Community patterns around characters — top 3 per time window</p>

        @if (loadingGlobalCharacterStats)
        {
            <MudProgressLinear Color="MudBlazor.Color.Primary" Indeterminate="true" Class="mb-4" />
        }
        else if (globalCharacterStats != null)
        {
            <MudExpansionPanels MultiExpansion="true">
                <MudExpansionPanel Text="🤔 Most Confusing — guessed most often as the wrong answer">
                    @CharacterTop3Table(globalCharacterStats.MostConfusing, "Times guessed (wrong)")
                </MudExpansionPanel>
                <MudExpansionPanel Text="✅ Easiest to Guess — most frequent winning answer">
                    @CharacterTop3Table(globalCharacterStats.Easiest, "Times as winning answer")
                </MudExpansionPanel>
                <MudExpansionPanel Text="💡 The Indicator — guess that led to a win on the very next guess">
                    @CharacterTop3Table(globalCharacterStats.TheIndicator, "Times as winning indicator")
                </MudExpansionPanel>
                <MudExpansionPanel Text="🚀 The Opener — most popular first guess in winning games">
                    @CharacterTop3Table(globalCharacterStats.TheOpener, "Times as winning opener")
                </MudExpansionPanel>
            </MudExpansionPanels>
        }
    </section>

</WebPage>

@code {
    private RenderFragment CharacterTop3Table(CharacterWindowStats stats, string countLabel) =>
        @<div>
            @foreach (var window in new[] {
                (Label: "Yesterday", Entries: stats.Yesterday),
                (Label: "Past 7 Days", Entries: stats.PastWeek),
                (Label: "Past 30 Days", Entries: stats.PastMonth)
            })
            {
                <div class="mb-2">
                    <MudText Typo="Typo.subtitle2" Class="mb-1">@window.Label</MudText>
                    @if (!window.Entries.Any())
                    {
                        <span class="mud-text-secondary">No data</span>
                    }
                    else
                    {
                        @foreach (var entry in window.Entries)
                        {
                            <MudChip T="string" Size="Size.Small" Class="mr-1 mb-1">
                                <MudAvatar Style="width:20px;height:20px;margin-right:4px;" Square="true">
                                    <MudImage Src="@($"/graphics/mini-heads/{entry.CharacterName}.webp")" />
                                </MudAvatar>
                                @entry.CharacterName (@entry.Count)
                            </MudChip>
                        }
                    }
                </div>
            }
        </div>;

    // Global Stats
    private long TotalPlayers { get; set; }
    private long TotalGamesPlayed { get; set; }
    private double GlobalWinRate { get; set; }

    // Player Daily Stats
    private Guid PlayerId { get; set; }

    private int DailyGamesPlayed { get; set; }
    private int DailyGamesWon { get; set; }
    private int LongestStreak { get; set; }

    private double DailyWinRate { get; set; }

    private int[] GuessDistribution { get; set; } = [];

    // Player Practice Stats
    private int PracticeGamesStarted { get; set; }
    private int PracticeGamesFinished { get; set; }
    private int PracticeGamesWon { get; set; }

    private double FinishedPracticeWinRate => PracticeGamesFinished == 0 ? 0 : (PracticeGamesWon * 100) / (double)PracticeGamesFinished;
    private double AllPracticeWinRate => PracticeGamesStarted == 0 ? 0 : (PracticeGamesWon * 100) / (double)PracticeGamesStarted;

    // Player Activity Data
    private List<DailyActivePlayersData>? dauData;
    private List<NewVsReturningPlayersData>? newVsReturningData;
    private PlayerActivityDistributionData[]? activityDistribution;
    private GamesPerPlayerStats? gamesPerPlayer;
    private RetentionStats? retention;

    // Character Stats
    private PlayerCharacterStats? playerCharacterStats;
    private GlobalCharacterStats? globalCharacterStats;

    private int selectedDays = 7;
    private bool loadingActivity = true;
    private bool loadingRetention = true;
    private bool loadingCharacterStats = true;
    private bool loadingGlobalCharacterStats = true;
    private bool initialLoadCompleted;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || initialLoadCompleted)
        {
            return;
        }

        try
        {
            await ExecuteWithDiagnosticsAsync(nameof(CollectGlobalDataAsync), CollectGlobalDataAsync);
            await ExecuteWithDiagnosticsAsync(nameof(CollectPlayerActivityDataAsync), CollectPlayerActivityDataAsync);
            await ExecuteWithDiagnosticsAsync(nameof(CollectRetentionDataAsync), CollectRetentionDataAsync);
            await ExecuteWithDiagnosticsAsync(nameof(CollectPlayerDataAsync), CollectPlayerDataAsync);
            await ExecuteWithDiagnosticsAsync(nameof(CollectGlobalCharacterStatsAsync), CollectGlobalCharacterStatsAsync);

            initialLoadCompleted = true;
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task CollectPlayerDataAsync()
    {
        var stats = await PlayerStatsStore.LoadAsync();
        PlayerId = stats.Id;
        DailyGamesPlayed = stats.GamesPlayed;
        DailyGamesWon = stats.GamesWon;
        LongestStreak = stats.MaxStreak;

        DailyWinRate = stats.WinRate;

        GuessDistribution = stats.GuessDistribution;

        var gameStats = await GameStatsStore.GetPlayerGames(PlayerId);

        var practiceGames = gameStats.Where(game => game.Mode.Equals(GameMode.Practice)).Distinct();

        PracticeGamesStarted = practiceGames.Count();

        var finishedPracticeGames = practiceGames.Where(game => game.FinishedOnUtc is not null);

        PracticeGamesFinished = finishedPracticeGames.Count();

        PracticeGamesWon = finishedPracticeGames.Count(game => game.IsWon);

        loadingCharacterStats = true;
        try
        {
            if (PlayerId != Guid.Empty)
            {
                var rawPlayerCharStats = await GameStatsStore.GetPlayerCharacterStatsAsync(PlayerId);
                var lookups = await CharacterStore.GetLookupsAsync();
                playerCharacterStats = new PlayerCharacterStats
                {
                    MostGuessedCharacterId = rawPlayerCharStats.MostGuessedCharacterId,
                    MostGuessedCharacterName = rawPlayerCharStats.MostGuessedCharacterId.HasValue
                        ? (lookups.FirstOrDefault(l => l.Id == rawPlayerCharStats.MostGuessedCharacterId.Value)?.Name ?? rawPlayerCharStats.MostGuessedCharacterId.Value.ToString())
                        : null,
                    MostGuessedCount = rawPlayerCharStats.MostGuessedCount,
                    MostCorrectlyGuessedCharacterId = rawPlayerCharStats.MostCorrectlyGuessedCharacterId,
                    MostCorrectlyGuessedCharacterName = rawPlayerCharStats.MostCorrectlyGuessedCharacterId.HasValue
                        ? (lookups.FirstOrDefault(l => l.Id == rawPlayerCharStats.MostCorrectlyGuessedCharacterId.Value)?.Name ?? rawPlayerCharStats.MostCorrectlyGuessedCharacterId.Value.ToString())
                        : null,
                    MostCorrectlyGuessedCount = rawPlayerCharStats.MostCorrectlyGuessedCount,
                };
            }
        }
        finally
        {
            loadingCharacterStats = false;
        }
    }

    private async Task CollectGlobalDataAsync()
    {
        var globalData = await GameStatsStore.GetGlobalStatsAsync();

        TotalPlayers = globalData.TotalPlayers;
        TotalGamesPlayed = globalData.TotalGames;
        GlobalWinRate = globalData.WinRate;
    }

    private async Task CollectPlayerActivityDataAsync()
    {
        loadingActivity = true;

        try
        {
            await LoadRangeDependentActivityDataAsync(selectedDays);
            activityDistribution = await GameStatsStore.GetPlayerActivityDistributionAsync();
            gamesPerPlayer = await GameStatsStore.GetGamesPerPlayerStatsAsync();
        }
        finally
        {
            loadingActivity = false;
        }
    }

    private async Task CollectRetentionDataAsync()
    {
        loadingRetention = true;

        try
        {
            retention = await GameStatsStore.GetRetentionStatsAsync();
        }
        finally
        {
            loadingRetention = false;
        }
    }

    private async Task CollectGlobalCharacterStatsAsync()
    {
        loadingGlobalCharacterStats = true;

        try
        {
            var raw = await GameStatsStore.GetGlobalCharacterStatsAsync();
            var lookups = await CharacterStore.GetLookupsAsync();

            IReadOnlyList<CharacterStatEntry> Resolve(IReadOnlyList<CharacterStatEntry> entries) =>
                entries.Select(e => e with
                {
                    CharacterName = lookups.FirstOrDefault(l => l.Id == e.CharacterId)?.Name ?? e.CharacterId.ToString()
                }).ToList();

            globalCharacterStats = new GlobalCharacterStats
            {
                MostConfusing = new CharacterWindowStats
                {
                    Yesterday = Resolve(raw.MostConfusing.Yesterday),
                    PastWeek = Resolve(raw.MostConfusing.PastWeek),
                    PastMonth = Resolve(raw.MostConfusing.PastMonth),
                },
                Easiest = new CharacterWindowStats
                {
                    Yesterday = Resolve(raw.Easiest.Yesterday),
                    PastWeek = Resolve(raw.Easiest.PastWeek),
                    PastMonth = Resolve(raw.Easiest.PastMonth),
                },
                TheIndicator = new CharacterWindowStats
                {
                    Yesterday = Resolve(raw.TheIndicator.Yesterday),
                    PastWeek = Resolve(raw.TheIndicator.PastWeek),
                    PastMonth = Resolve(raw.TheIndicator.PastMonth),
                },
                TheOpener = new CharacterWindowStats
                {
                    Yesterday = Resolve(raw.TheOpener.Yesterday),
                    PastWeek = Resolve(raw.TheOpener.PastWeek),
                    PastMonth = Resolve(raw.TheOpener.PastMonth),
                },
            };
        }
        finally
        {
            loadingGlobalCharacterStats = false;
        }
    }

    private async Task OnTimeRangeChanged(int days)
    {
        if (loadingActivity)
        {
            return;
        }

        await ExecuteWithDiagnosticsAsync($"{nameof(OnTimeRangeChanged)}:{days}", async () =>
        {
            loadingActivity = true;
            selectedDays = days;
            await InvokeAsync(StateHasChanged);

            try
            {
                await LoadRangeDependentActivityDataAsync(days);
            }
            finally
            {
                loadingActivity = false;
                await InvokeAsync(StateHasChanged);
            }
        });
    }

    private async Task LoadRangeDependentActivityDataAsync(int days)
    {
        var from = CalculateFromDate(days);

        dauData = await GameStatsStore.GetDailyActivePlayersAsync(from);
        newVsReturningData = await GameStatsStore.GetNewVsReturningPlayersAsync(from);
    }

    private async Task ExecuteWithDiagnosticsAsync(string operationName, Func<Task> operation)
    {
        Logger.LogInformation("Stats load {Operation} START", operationName);

        try
        {
            await operation();
            Logger.LogInformation("Stats load {Operation} SUCCESS", operationName);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Stats load {Operation} FAILED", operationName);
            throw;
        }
        finally
        {
            Logger.LogInformation("Stats load {Operation} END", operationName);
        }
    }

    private static DateOnly? CalculateFromDate(int days)
    {
        if (days == 0) return null;

        var today = DateOnly.FromDateTime(DateTime.UtcNow);
        return days == 7 ? today.AddDays(-6) : today.AddDays(-29);
    }
}
