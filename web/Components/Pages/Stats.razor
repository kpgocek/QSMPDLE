@page "/stats"

@using MudBlazor
@using QSMPDLE.Web.Components.UX
@using QSMPDLE.Web.Components.Statistics
@using QSMPDLE.Web.Features.Statistics.Models
@using QSMPDLE.Web.Infrastructure.LocalStorage
@using QSMPDLE.Web.Infrastructure.Persistence

@inject IPlayerStatsStore PlayerStatsStore
@inject IGameStatsStore GameStatsStore
@inject ICharacterStore CharacterStore

<PageTitle>Game Statistics - QSMPDLE</PageTitle>

<WebPage>

    <section class="mb-2">
        <h2>
            Statistics & Telemetry
        </h2>

        <p class="info">
            Some interesting information about our players
        </p>

        <MudAlert Severity="Severity.Success" Dense="true" Variant="Variant.Outlined" Class="mb-6">
            <strong>Data's incomplete.</strong> We only started collecting gameplay stats from the 1.1 release.
        </MudAlert>  
        
        <MudGrid>
            <MudItem xs="6" sm="3" Style="display:flex;">
                <StatCard Title="Players" Delay="100" Icon="@Icons.Material.Filled.PeopleAlt"
                          Value="@($"{TotalPlayers}")" />
            </MudItem>

            <MudItem xs="6" sm="3" Style="display:flex;">
                <StatCard Title="Total Games Played" Delay="200" Icon="@Icons.Material.Filled.EmojiEvents"
                          Value="@($"{TotalGamesPlayed}")" />
            </MudItem>

            <MudItem xs="6" sm="3" Style="display:flex;">
                <StatCard Title="Global Win Rate" Delay="300" Icon="@Icons.Material.Filled.LocalFireDepartment"
                          Value="@($"{GlobalWinRate:0}%")" />
            </MudItem>
        </MudGrid>

    </section>

    <section class="mb-5">
        <h3>
            Your Personal Stats
        </h3>
        
        
        <section class="mb-5">

            <MudImage Src="" />

        </section>

        <section class="mb-5">
            <h4>
                Daily Mode
            </h4>

            <MudGrid>
                <MudItem xs="6" sm="3" Style="display:flex;">
                    <StatCard Title="Played" Delay="100" Icon="@Icons.Material.Filled.SportsEsports"
                              Value="@($"{DailyGamesPlayed}")" />
                </MudItem>

                <MudItem xs="6" sm="3" Style="display:flex;">
                    <StatCard Title="Won" Delay="200" Icon="@Icons.Material.Filled.EmojiEvents"
                              Value="@($"{DailyGamesWon}")" />
                </MudItem>

                <MudItem xs="6" sm="3" Style="display:flex;">
                    <StatCard Title="Win Rate" Delay="300" Icon="@Icons.Material.Filled.LocalFireDepartment"
                              Value="@($"{DailyWinRate:0}%")" />
                </MudItem>

                <MudItem xs="6" sm="3" Style="display:flex;">
                    <StatCard Title="Best Streak" Delay="400" Icon="@Icons.Material.Filled.BarChart"
                              Value="@($"{LongestStreak}")"/>
                </MudItem>
            </MudGrid>

        </section>

        <section class="mb-5">
            <h4>
                Practice Mode
            </h4>

            <MudGrid>
                <MudItem xs="6" sm="3" Style="display:flex;">
                    <StatCard Title="Started" Delay="150" Icon="@Icons.Material.Filled.PlayArrow"
                              Value="@($"{PracticeGamesStarted}")" Comment="Yes, even skipped ones"/>
                </MudItem>

                <MudItem xs="6" sm="3" Style="display:flex;">
                    <StatCard Title="Finished" Delay="250" Icon="@Icons.Material.Filled.CheckCircle"
                              Value="@($"{PracticeGamesFinished}")" />
                </MudItem>

                <MudItem xs="6" sm="3" Style="display:flex;">
                    <StatCard Title="Won" Delay="350" Icon="@Icons.Material.Filled.WorkspacePremium"
                              Value="@($"{PracticeGamesWon}")" />
                </MudItem>

                <MudItem xs="6" sm="3" Style="display:flex;">
                    <StatCard Title="Win Rate" Delay="450" Icon="@Icons.Material.Filled.BarChart"
                              Value="@($"{AllPracticeWinRate:0}%")" Comment="@($"{FinishedPracticeWinRate:0}% of finished games")" />
                </MudItem>
            </MudGrid>
        
        </section>
    </section>

    <section class="mb-5">
        <h3>Player Activity</h3>

        <div class="mb-4">
            <MudButtonGroup Color="MudBlazor.Color.Primary" Variant="Variant.Outlined">
                <MudButton OnClick="@(() => OnTimeRangeChanged(7))"
                           Disabled="@loadingActivity"
                           Variant="@(selectedDays == 7 ? Variant.Filled : Variant.Outlined)">
                    Last 7 Days
                </MudButton>
                <MudButton OnClick="@(() => OnTimeRangeChanged(30))"
                           Disabled="@loadingActivity"
                           Variant="@(selectedDays == 30 ? Variant.Filled : Variant.Outlined)">
                    Last 30 Days
                </MudButton>
                <MudButton OnClick="@(() => OnTimeRangeChanged(0))"
                           Disabled="@loadingActivity"
                           Variant="@(selectedDays == 0 ? Variant.Filled : Variant.Outlined)">
                    All Time
                </MudButton>
            </MudButtonGroup>
        </div>

        @if (loadingActivity)
        {
            <MudProgressLinear Color="MudBlazor.Color.Primary" Indeterminate="true" Class="mb-4" />
        }
        else
        {
            <DailyActivePlayersChart Data="@dauData" />
            <NewVsReturningChart Data="@newVsReturningData" />
            <ActivityDistributionChart Data="@activityDistribution" />

            <MudGrid Class="mt-4">
                <MudItem xs="6" sm="4" Style="display:flex;">
                    <StatCard Title="Average Games Per Player" Delay="500" Icon="@Icons.Material.Filled.Calculate"
                              Value="@(gamesPerPlayer != null ? $"{gamesPerPlayer.Average:0.0}" : "-")" />
                </MudItem>

                <MudItem xs="6" sm="4" Style="display:flex;">
                    <StatCard Title="Median Games Per Player" Delay="600" Icon="@Icons.Material.Filled.Functions"
                              Value="@(gamesPerPlayer != null ? $"{gamesPerPlayer.Median:0}" : "-")" />
                </MudItem>

                <MudItem xs="6" sm="4" Style="display:flex;">
                    <StatCard Title="Maximum Games Per Player" Delay="700" Icon="@Icons.Material.Filled.EmojiEvents"
                              Value="@(gamesPerPlayer != null ? $"{gamesPerPlayer.Maximum}" : "-")" />
                </MudItem>
            </MudGrid>
        }
    </section>

    <section class="mb-5">
        <h3>Player Retention</h3>
        <p class="info mb-4">
            Percentage of players who returned to play exactly N days after their first game
        </p>

        @if (loadingRetention)
        {
            <MudProgressLinear Color="MudBlazor.Color.Primary" Indeterminate="true" Class="mb-4" />
        }
        else
        {
            <MudGrid>
                <MudItem xs="6" sm="6" Style="display:flex;">
                    <StatCard Title="D1 Retention" Delay="800" Icon="@Icons.Material.Filled.TrendingUp"
                              Value="@(retention != null ? $"{retention.D1Retention:0.0}%" : "-")" 
                              Comment="Returned after 1 day" />
                </MudItem>

                <MudItem xs="6" sm="6" Style="display:flex;">
                    <StatCard Title="D7 Retention" Delay="900" Icon="@Icons.Material.Filled.ShowChart"
                              Value="@(retention != null ? $"{retention.D7Retention:0.0}%" : "-")" 
                              Comment="Returned after 7 days" />
                </MudItem>
            </MudGrid>
        }
    </section>

    <section class="mb-5">
        <h3>
            Global Stats (W.I.P.)
        </h3>
    </section>

</WebPage>

@code {
    // Global Stats
    private long TotalPlayers { get; set; }
    private long TotalGamesPlayed { get; set; }
    private double GlobalWinRate { get; set; }

    // Player Daily Stats
    private Guid PlayerId { get; set; }

    private int DailyGamesPlayed { get; set; }
    private int DailyGamesWon { get; set; }
    private int LongestStreak { get; set; }

    private double DailyWinRate { get; set; }

    private int[] GuessDistribution { get; set; } = [];

    // Player Practice Stats
    private int PracticeGamesStarted { get; set; }
    private int PracticeGamesFinished { get; set; }
    private int PracticeGamesWon { get; set; }

    private double FinishedPracticeWinRate => PracticeGamesFinished == 0 ? 0 : (PracticeGamesWon * 100) / (double) PracticeGamesFinished;
    private double AllPracticeWinRate => PracticeGamesStarted == 0 ? 0 : (PracticeGamesWon * 100) / (double)PracticeGamesStarted;

    // Player Activity Data
    private List<DailyActivePlayersData>? dauData;
    private List<NewVsReturningPlayersData>? newVsReturningData;
    private PlayerActivityDistributionData[]? activityDistribution;
    private GamesPerPlayerStats? gamesPerPlayer;
    private RetentionStats? retention;

    private int selectedDays = 7;
    private bool loadingActivity = true;
    private bool loadingRetention = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        Console.WriteLine("START Player");
        await CollectPlayerDataAsync();
        Console.WriteLine("END Player");

        Console.WriteLine("START Global");
        await CollectGlobalDataAsync();
        Console.WriteLine("END Global");

        Console.WriteLine("START Activity");
        await CollectPlayerActivityDataAsync();
        Console.WriteLine("END Activity");

        Console.WriteLine("START Retention");
        await CollectRetentionDataAsync();
        Console.WriteLine("END Retention");

        await InvokeAsync(StateHasChanged);
    }

    private async Task CollectPlayerDataAsync()
    {
        var stats = await PlayerStatsStore.LoadAsync();
        PlayerId = stats.Id;
        DailyGamesPlayed = stats.GamesPlayed;
        DailyGamesWon = stats.GamesWon;
        LongestStreak = stats.MaxStreak;

        DailyWinRate = stats.WinRate;

        GuessDistribution = stats.GuessDistribution;

        var gameStats = await GameStatsStore.GetPlayerGames(PlayerId);

        var practiceGames = gameStats.Where(game => game.Mode.Equals(GameMode.Practice)).Distinct();

        PracticeGamesStarted = practiceGames.Count();

        var finishedPracticeGames = practiceGames.Where(game => game.FinishedOnUtc is not null);

        PracticeGamesFinished = finishedPracticeGames.Count();

        PracticeGamesWon = finishedPracticeGames.Where(game => game.IsWon == true).Count();
    }

    private async Task CollectGlobalDataAsync()
    {
        var globalData = await GameStatsStore.GetGlobalStatsAsync();

        Console.WriteLine(
            $"GLOBAL DATA: Players={globalData.TotalPlayers}, " +
            $"Games={globalData.TotalGames}, " +
            $"Wins={globalData.TotalWins}");

        TotalPlayers = globalData.TotalPlayers;
        TotalGamesPlayed = globalData.TotalGames;
        GlobalWinRate = globalData.WinRate;
    }

    private async Task CollectPlayerActivityDataAsync()
    {
        try
        {
            loadingActivity = true;

            var from = CalculateFromDate(selectedDays);

            dauData = await GameStatsStore.GetDailyActivePlayersAsync(from);
            newVsReturningData = await GameStatsStore.GetNewVsReturningPlayersAsync(from);
            activityDistribution = await GameStatsStore.GetPlayerActivityDistributionAsync();
            gamesPerPlayer = await GameStatsStore.GetGamesPerPlayerStatsAsync();

            Console.WriteLine($"DAU COUNT: {dauData?.Count}");
            Console.WriteLine($"NEW/RETURNING COUNT: {newVsReturningData?.Count}");
            Console.WriteLine($"DISTRIBUTION COUNT: {activityDistribution?.Length}");
            Console.WriteLine(
                $"GAMES/PLAYER: Avg={gamesPerPlayer?.Average}, " +
                $"Median={gamesPerPlayer?.Median}, " +
                $"Max={gamesPerPlayer?.Maximum}");
        }
        finally
        {
            loadingActivity = false;
        }
    }

    private async Task CollectRetentionDataAsync()
    {
        try
        {
            loadingRetention = true;

            retention = await GameStatsStore.GetRetentionStatsAsync();

            Console.WriteLine(
                $"RETENTION: D1={retention?.D1Retention}, " +
                $"D7={retention?.D7Retention}");
        }
        finally
        {
            loadingRetention = false;
        }
    }

    private async Task OnTimeRangeChanged(int days)
    {
        if (loadingActivity)
        {
            return;
        }

        try
        {
            loadingActivity = true;
            selectedDays = days;
            await InvokeAsync(StateHasChanged);

            var from = CalculateFromDate(days);

            dauData = await GameStatsStore.GetDailyActivePlayersAsync(from);
            newVsReturningData = await GameStatsStore.GetNewVsReturningPlayersAsync(from);
        }
        finally
        {
            loadingActivity = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static DateOnly? CalculateFromDate(int days)
    {
        if (days == 0) return null; // All time

        var today = DateOnly.FromDateTime(DateTime.UtcNow);
        // Corrected off-by-one: Last 7 days = Today - 6, Last 30 days = Today - 29
        return days == 7 ? today.AddDays(-6) : today.AddDays(-29);
    }
}
