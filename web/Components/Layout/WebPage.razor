@using MudBlazor

<MudContainer MaxWidth="MaxWidth.Medium" Class="px-0 py-2">

    <MudPaper Elevation="2" Class="card pa-3">
        @ChildContent
    </MudPaper>

</MudContainer>

<style>
    .card {
        position: relative;

        max-width: 850px;
        margin: 0 auto;
        background: linear-gradient(to bottom, transparent 40%, var(--shadow) 90%);
        backdrop-filter: blur(16px);
        color: var(--white);
        border: none;
    }

    .info {
        color: var(--primary);
    }

    .section-title {
        margin-bottom: 1rem;
        font-weight: 700;
    }
</style>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
