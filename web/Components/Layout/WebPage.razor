@using MudBlazor

<MudContainer MaxWidth="MaxWidth.Medium" Class="px-0 py-2">

    <MudPaper Elevation="2" Class="card pa-3">
        @ChildContent
    </MudPaper>

</MudContainer>

<style>
    .card {
        position: relative;

        max-width: 53.125rem;
        margin: 0 auto;
        background: linear-gradient(180deg, var(--panel), hsla(var(--primary-hsl), 0.09));
        backdrop-filter: blur(1rem);
        color: var(--white);
        border: .125rem solid var(--panel-edge);
        border-radius: .75rem;
        box-shadow: inset 0 0 0 .0625rem var(--black);
    }

    .info {
        color: var(--primary);
    }

    .section-title {
        margin-bottom: 1rem;
        font-weight: 700;
    }
</style>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
