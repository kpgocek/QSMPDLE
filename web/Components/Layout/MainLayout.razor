@using MudBlazor
@using BlazorBootstrap
@using QSMPDLE.Web.Themes

@inherits LayoutComponentBase

<MudPopoverProvider />
<MudBreakpointProvider />
<MudThemeProvider Theme="@QsmpdleTheme.Theme" IsDarkMode="true" />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="page">

    <div class="content">

        <NavMenu />

        <main>
            @Body
        </main>

    </div>

    <footer class="footer">
        <div class="footer-content">

            <div class="footer-logo">
                QSMPDLE
            </div>

            <div class="footer-links">
                <a href="https://github.com/kpgocek/QSMPDLE">GitHub</a>
                <a href="/changelog">Changelog</a>
                <a href="/privacy">Privacy</a>
                <a href="https://x.com/qsmpdle" target="_blank" rel="noopener noreferrer">X</a>
                <a href="https://ko-fi.com/qsmpdle" target="_blank" rel="noopener noreferrer">Support</a>
            </div>

            <div class="footer-disclaimer">
                Fan project. Not affiliated with QSMP or its creators.
            </div>

            <div class="footer-copyright">
                Copyright © 2026 by KPG
            </div>

        </div>
    </footer>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

<Preload LoadingText="Loading..." />
