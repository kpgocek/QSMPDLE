@using System.Diagnostics
@using MudBlazor
@using MudBlazor.Charts
@using QSMPDLE.Web.Features.Statistics.Models
@using QSMPDLE.Web.Themes

@inject ThemeService Themes;

<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-4">Daily Active Players</MudText>

    @if (ChartData == null || !ChartData.Any())
    {
        <MudText Typo="Typo.body2" Color="MudBlazor.Color.Secondary">No data available</MudText>
    }
    else
    {
        <MudChart ChartType="ChartType.Line" ChartSeries="@Series" ChartLabels="@DateLabels" ChartOptions="@Options"
                  Width="100%" Height="300px" @bind-SelectedIndex="@Index" MatchBoundsToSize="true">
        </MudChart>
    }
</MudPaper>

    @code {

    [Parameter]
    public List<DailyActivePlayersData>? ChartData { get; set; }

    private int Index = -1;
    private LineChartOptions Options = new LineChartOptions()
    {
        XAxisTitle = "Days",
        InterpolationOption = InterpolationOption.NaturalSpline,
    };

    private string[] DateLabels = [];

    private List<ChartSeries<int>> Series = [];

    protected override void OnInitialized()
    {
        base.OnInitialized();

        if (ChartData is null) throw new NullReferenceException(nameof(DailyActivePlayersData));

        Series.Add(new ChartSeries<int>() { Name = "Active Players", Data = ChartData.Select(x => x.PlayerCount).ToArray() });
        DateLabels = ChartData.Select(x => x.Date.ToShortDateString()).ToArray();

        Options.SeriesDisplayOverrides = new Dictionary<IChartSeries, SeriesDisplayOverride>()
        {
            { Series[0], new SeriesDisplayOverride() }
        };

        var palette = Themes.CurrentTheme.PaletteDark;

        Options.ChartPalette = [
            palette.Primary.ToString(),
            palette.Secondary.ToString(),
            palette.Success.ToString(),
            palette.Warning.ToString(),
            palette.PrimaryLighten,
            palette.SuccessLighten,
            palette.WarningLighten,
            palette.SecondaryLighten,
            palette.PrimaryDarken,
            palette.SuccessDarken,
            palette.WarningDarken,
            palette.SecondaryDarken
        ];
    }

    
}
