@using MudBlazor
@using QSMPDLE.Web.Components.UX
@using QSMPDLE.Web.Data.Gameplay
@using QSMPDLE.Web.Services

<div class="mobile-guesses">

    @for (int i = Guesses.Count; i < MaxGuesses; i++)
    {
        <div class="placeholder-card opacity-@(i)">

            <div class="placeholder-card-header">
                <MudAvatar Square="true" Class="placeholder-avatar" Size="Size.Large" />
            </div>

            <div class="placeholder-card-grid">

                <MudChip T="string" Class="placeholder-chip">
                    &nbsp;
                </MudChip>

                <MudChip T="string" Class="placeholder-chip">
                    &nbsp;
                </MudChip>

                <MudChip T="string" Class="placeholder-chip">
                    &nbsp;
                </MudChip>

                <MudChip T="string" Class="placeholder-chip">
                    &nbsp;
                </MudChip>

                <MudChip T="string" Class="placeholder-chip">
                    &nbsp;
                </MudChip>

            </div>
        </div>
    }

    @foreach (var guess in Guesses)
    {
        <div class="guess-card">

            <div class="guess-card-header">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexStart" Spacing="2">
                    <MudAvatar Square="true" Size="Size.Large">
                        <MudImage Src="@ImageHelper.GetMemberHead(guess.Member)" />
                    </MudAvatar>

                    <span class="guess-name">@guess.Member.Name</span>
                </MudStack>
            </div>

            <div class="guess-card-grid">

                <GuessChip Result="guess.Pronouns">
                    @(guess.Member.Pronouns.Contains("Any") ? "Pronouns: Any" : @DisplayList(guess.Member.Pronouns))
                </GuessChip>

                <GuessChip Result="guess.Species">
                    @(guess.Member.Species.Contains("Human")
                        ? "Human"
                        : @guess.Member.Species.Contains("Unknown")
                            ? "Species: Unknown"
                            : $"Not Human")
                </GuessChip>


                <GuessChip Result="guess.Languages">
                    <span class="chip-labels">Languages:</span>
                    @(@guess.Member.Languages > 3
                        ? $"3+"
                        : @guess.Member.Languages)
                </GuessChip>


                @foreach (var affiliation in guess.Member.Affiliations)
                {
                    <GuessChip Result="guess.Affiliation">
                        @affiliation
                    </GuessChip>

                }
                <GuessChip Result="guess.Joined">
                    <span class="chip-labels">Joined on</span> Day @guess.Member.JoinDayNumber
                </GuessChip>

            </div>
        </div>
    }

</div>

<style>
    .guess-card,
    .placeholder-card {
        padding: 1rem;

        background:
            linear-gradient(to top left, var(--primary-black) 50%, var(--tint) 200%);

        backdrop-filter: blur(1rem);

        border-radius: 0;
        border-inline: none;
        border-block: .125rem solid var(--shadow);
    }

    .placeholder-card {
        opacity: 0.5;
    }

    .guess-card-grid,
    .placeholder-card-grid {
        display: grid;

        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));

        gap: .5rem;

        margin-top: 1rem;
    }

    .guess-card-grid .mud-chip,
    .placeholder-card-grid .mud-chip {
        width: 100%;
    }

    .guess-avatar,
    .placeholder-avatar {
        width: 5rem;
        height: 5rem;

        image-rendering: pixelated;
        background: var(--ghost);
        border: 1px solid var(--ghost);
    }

    .placeholder-avatar {
        opacity: .4;
    }

    .guess-name {
        font-size: 1.1rem;
        font-weight: 500;
        letter-spacing: .02em;
    }

    .placeholder-text {
        color: rgba(255, 255, 255, .25);
    }

    .placeholder-chip {
        width: 6rem;
        margin: 0 auto;

        opacity: .25;
        pointer-events: none;
    }
</style>


@code {
    [Parameter]
    public IReadOnlyList<Guess> Guesses { get; set; } = null!;

    [Parameter]
    public int MaxGuesses { get; set; } = 6;

    private static string DisplayList(IEnumerable<string> values)
    {
        return values.Any()
            ? string.Join(", ", values)
            : "None";
    }
}
