@using MudBlazor
@using QSMPDLE.Web.Components.UX
@using QSMPDLE.Web.Features.Gameplay.Models
@using QSMPDLE.Web.Infrastructure.Persistence

@inject ICharacterStore CharacterStore

@if (Guesses is not null)
{
    <table class="guess-table mx-auto">
        <thead>
            <tr>
                <th>Character</th>
                <th>
                    <MudTooltip Text="Including 'Any'">
                        <span class="header-with-icon">Pronouns
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
                        </span>
                    </MudTooltip>
                </th>

                <th>
                    <MudTooltip Text="'Human', 'Not Human' or 'Unknown'">
                        <span class="header-with-icon">Species
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
                        </span>
                    </MudTooltip>
                </th>
                <th>Languages</th>
                <th>Affiliations</th>
                <th>Joined</th>
            </tr>
        </thead>
        <tbody>

            @foreach (var guess in Guesses)
            {
                var character = GetCharacter(guess.Character.Id);

                if (character is null)
                {
                    continue;
                }

                <tr class="answer-row @(guess == Guesses.Last() ? "new-row" : "")">
                    <td class="medium-cell">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Square="true" Size="Size.Large">
                                <MudImage Src="@CharacterImageHelper.GetHeadSrc(character)" />
                            </MudAvatar>
                            <span>@character.Name</span>
                        </MudStack>
                    </td>

                    <td class="small-cell">
                        <GuessChip Result="guess.Pronouns">
                            @DisplayList(character.Pronouns)
                        </GuessChip>
                    </td>

                    <td class="medium-cell">
                        <GuessChip Result="guess.Species">
                            @FormatSpecies(character)
                        </GuessChip>

                    </td>

                    <td class="small-cell">
                        <GuessChip Result="guess.Languages">
                            @(character.Languages > 3 ? $"4+ ({character.Languages})" : character.Languages)
                        </GuessChip>
                    </td>

                    <td class="large-cell">
                        <GuessChip Result="guess.Affiliation">
                            @DisplayList(character.Affiliations)
                        </GuessChip>
                    </td>

                    <td class="small-cell">
                        <GuessChip Result="guess.Joined">
                            Day @character.JoinDayNumber
                        </GuessChip>
                    </td>
                </tr>
            }

            @for (int i = Guesses.Count; i < MaxGuesses; i++) // 1-2-3-4-5-6
            {
                <tr class="empty-row opacity-@(MaxGuesses + Guesses.Count - i)">
                    <td class="large-cell">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudAvatar Square="true" Class="placeholder-avatar" Size="Size.Large" />

                            <span class="placeholder-name">&nbsp;</span>
                        </MudStack>
                    </td>

                    <td class="small-cell">
                        <MudChip T="string" Class="placeholder-chip">
                            &nbsp;
                        </MudChip>

                    </td>
                    <td class="medium-cell">
                        <MudChip T="string" Class="placeholder-chip">
                            &nbsp;
                        </MudChip>

                    </td>
                    <td class="small-cell">

                        <MudChip T="string" Class="placeholder-chip">
                            &nbsp;
                        </MudChip>
                    </td>

                    <td class="large-cell">
                        <MudChip T="string" Class="placeholder-chip">
                            &nbsp;
                        </MudChip>
                    </td>
                    <td class="small-cell">
                        <MudChip T="string" Class="placeholder-chip">
                            &nbsp;
                        </MudChip>
                    </td>
                </tr>
            }

        </tbody>
    </table>
}

<style>
    .guess-table {
        min-width: 68rem;
        border-collapse: separate;
        border-spacing: 0 .5rem;
    }

    .guess-table tr {
        height: 3rem;
    }

    .guess-table th {
        color: var(--white);
        text-transform: uppercase;
        letter-spacing: .05em;
        font-weight: 400;
    }

    .guess-table td {
        min-width: 8rem;
    }

    .guess-table td,
    .guess-table th {
        vertical-align: middle;
    }

    .header-with-icon {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
    }

    .header-with-icon .mud-icon-root {
        position: relative;
        top: -.0625rem;
    }

    .answer-row {
        user-select: none;
        border: 0.125rem solid var(--panel-edge);
        background: linear-gradient(90deg, var(--panel-strong), var(--panel));
        box-shadow: inset 0 0 0 .0625rem var(--black);
        transition:
            border-color 160ms ease,
            background-color 160ms ease;
    }

    .answer-row:hover {
        border-color: var(--line-strong);
    }

    .empty-row {
        user-select: none;
        border: 0.125rem solid var(--line);
        background: hsla(var(--primary-hsl), 0.1);
    }

    .small-cell {
        width: 9rem;
    }

    .medium-cell {
        width: 13rem;
    }

    .large-cell {
        width: 15rem;
    }

    .placeholder-avatar {
        background: rgba(255, 255, 255, .08);
        border: .0625rem solid rgba(255, 255, 255, .15);
        opacity: .4;
    }

    .placeholder-name {
        width: 7rem;
        background: rgba(255, 255, 255, .08);
    }

    .placeholder-text {
        color: rgba(255, 255, 255, .25);
    }

    .placeholder-chip {
        width: 6rem;
        height: 2rem;
        margin: 0 auto;

        opacity: .25;
        pointer-events: none;
    }

    .guess-card {
        background:
            linear-gradient(to top left, var(--panel-strong), var(--panel));
        border: .125rem solid var(--panel-edge);
        box-shadow: inset 0 0 0 .0625rem var(--black);

        border-radius: .5rem;

        padding: 1rem;

        backdrop-filter: blur(1rem);
    }

    .placeholder-card {
        background:
            linear-gradient(to top left, var(--surface), hsla(var(--primary-hsl), 0.08));
        border: .125rem solid var(--line);

        border-radius: .5rem;

        opacity: 0.5;

        padding: 1rem;

        backdrop-filter: blur(1rem);
    }

    .guess-avatar {
        width: 5rem;
        height: 5rem;
        image-rendering: pixelated;
    }

    .guess-name {
        font-size: 1.1rem;
        font-weight: 500;
        letter-spacing: .02em;
    }

    .new-row {
        animation: reveal-row 300ms cubic-bezier(.2, .8, .2, 1);
    }
</style>

@code {
    [Parameter]
    public IReadOnlyList<GuessResult> Guesses { get; set; } = null!;

    [Parameter]
    public int MaxGuesses { get; set; } = 6;

    private Dictionary<int, Character> CharactersById { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        CharactersById = (await CharacterStore.GetCharactersAsync()).ToDictionary(character => character.Id);
    }

    private static string DisplayList(IEnumerable<string> values)
    {
        return values.Any()
            ? string.Join("/", values)
            : "None";
    }

    private Character? GetCharacter(int id)
    {
        return CharactersById.GetValueOrDefault(id);
    }

    private static string FormatSpecies(Character character) =>
        character.Species.Contains("Human")
            ? DisplayList(character.Species)
            : character.Species.Contains("Unknown")
                ? DisplayList(character.Species)
                : $"Not Human ({DisplayList(character.Species)})";
}
