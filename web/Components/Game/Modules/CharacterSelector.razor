@using QSMPDLE.Web.Infrastructure.Persistence

@inject ICharacterStore CharacterStore


<div class="selection-area">
    <div class="input-field">
        <input type="text" @bind="SearchText" @bind:event="oninput" @onkeydown="HandleKeyDown"
               placeholder="Type in character's name" disabled="@IsDisabled" />
    </div>

    @if (!IsDisabled && Suggestions.Any())
    {
        <div class="suggestions">
            @foreach (var item in Suggestions.Select((m, i) => new { Character = m, Index = i }))
            {
                <button type="button" class="suggestion @(item.Index == ActiveSuggestionIndex ? "active" : "")"
                        @onclick="() => SelectAndGuess(item.Character)">
                    <img src="@CharacterImageHelper.GetHeadSrc(item.Character)" alt="@item.Character.Name" loading="lazy" decoding="async" />
                    <div class="names">
                        <span>@item.Character.Name</span>
                    </div>
                </button>
            }
        </div>
    }
</div>

<style>
    .selection-area {
        position: relative;
        width: min(26rem, calc(100vw - 2rem));
    }

    .input-field {
        user-select: none;
    }

    .input-field input {
        padding: .25rem .375rem;

        width: 100%;


        background: var(--black);

        border: 0.125rem solid var(--primary-black);
        box-shadow: var(--focus-ring);

        color: var(--white);

        font-size: 1.375rem;
    }

    .input-field input:focus {
        border: 0.125em solid var(--primary);
        box-shadow: var(--focus-ring);
        outline: none;
    }

    .suggestions {
        width: 100%;
        position: absolute;
        top: calc(100%);

        display: flex;
        flex-direction: column;

        z-index: 500;

        background: var(--black);
        border: .0625rem solid var(--line-strong);

        box-shadow: var(--soft-shadow);
    }

    .suggestion {
        background: var(--primary-black);

        border: none;

        transition:
            background-color 160ms ease,
            color 160ms ease,
            transform 160ms ease;

        padding: .5rem .75rem;

        display: flex;
        align-items: center;
        gap: .75rem;

        justify-content: start;

        border: none;
        cursor: pointer;

    }

    .suggestion img {
        width: 2rem;
        height: 2rem;

        flex-shrink: 0;

        image-rendering: pixelated;
    }

    .names span {
        font-weight: 700;
    }

    .suggestion:hover,
    .suggestion.active {
        border-color: var(--tint);
        background-color: var(--surface);
        transform: translateX(.125rem);
    }
</style>

@code {
    [Parameter]
    public CharacterLookup? Value { get; set; }

    [Parameter]
    public EventCallback<CharacterLookup?> ValueChanged { get; set; }

    [Parameter]
    public EventCallback<CharacterLookup> OnGuessConfirmed { get; set; }

    [Parameter] public bool IsGuessed { get; set; }

    [Parameter] public bool IsBusy { get; set; }

    private string SearchText = "";

    private int ActiveSuggestionIndex = 0;

    private bool IsDisabled => IsGuessed || IsBusy;

    private IReadOnlyList<CharacterLookup> Characters = [];

    protected override async Task OnInitializedAsync()
    {
        Characters = await CharacterStore.GetLookupsAsync();
    }

    private async Task SelectAndGuess(CharacterLookup? character)
    {
        if (character is null)
            return;

        SearchText = "";
        Value = character;

        await ValueChanged.InvokeAsync(character);
        await OnGuessConfirmed.InvokeAsync(character);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        var suggestions = Suggestions.ToList();

        if (suggestions.Count == 0)
            return;

        switch (e.Key)
        {
            case "ArrowDown":
                ActiveSuggestionIndex = Math.Min(ActiveSuggestionIndex + 1, suggestions.Count - 1);
                break;

            case "ArrowUp":
                ActiveSuggestionIndex = Math.Max(ActiveSuggestionIndex - 1, 0);
                break;

            case "Enter":
                await SelectAndGuess(suggestions[ActiveSuggestionIndex]);
                break;

            default:
                ActiveSuggestionIndex = 0;
                break;
        }
    }

    private IEnumerable<CharacterLookup> Suggestions =>
    string.IsNullOrWhiteSpace(SearchText)
        ? []
        : Characters
            .Where(p =>
                p.Name.Contains(SearchText, StringComparison.OrdinalIgnoreCase))
    .Take(5);
}
