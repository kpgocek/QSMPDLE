@using MudBlazor
@using QSMPDLE.Web.Components.UX
@using QSMPDLE.Web.Features.Gameplay.Models
@using QSMPDLE.Web.Infrastructure.Persistence

@inject ICharacterStore CharacterStore

<div class="mobile-guesses">

    @for (int i = Guesses.Count; i < MaxGuesses; i++)
    {
        <div class="placeholder-card opacity-@(MaxGuesses + Guesses.Count - i)">

            <div class="placeholder-card-header">
                <MudAvatar Square="true" Class="placeholder-avatar" Size="Size.Large" />
            </div>

            <div class="placeholder-card-grid">

                <MudChip T="string" Class="placeholder-chip">
                    &nbsp;
                </MudChip>

                <MudChip T="string" Class="placeholder-chip">
                    &nbsp;
                </MudChip>

                <MudChip T="string" Class="placeholder-chip">
                    &nbsp;
                </MudChip>

                <MudChip T="string" Class="placeholder-chip">
                    &nbsp;
                </MudChip>

                <MudChip T="string" Class="placeholder-chip">
                    &nbsp;
                </MudChip>

            </div>
        </div>
    }

    @foreach (var guess in Guesses)
    {
        var character = GetCharacter(guess.Character.Id);

        if (character is null)
        {
            continue;
        }

        <div class="guess-card">

            <div class="guess-card-header">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexStart" Spacing="2">
                    <MudAvatar Square="true" Size="Size.Large">
                        <MudImage Src="@CharacterImageHelper.GetHeadSrc(character)" />
                    </MudAvatar>

                    <span class="guess-name">@character.Name</span>
                </MudStack>
            </div>

            <div class="guess-card-grid">

                <GuessChip Result="guess.Pronouns">
                    @(character.Pronouns.Contains("Any") ? "Pronouns: Any" : DisplayList(character.Pronouns))
                </GuessChip>

                <GuessChip Result="guess.Species">
                    @FormatSpecies(character)
                </GuessChip>


                <GuessChip Result="guess.Languages">
                    <span class="chip-labels">Languages:</span>
                    @(character.Languages > 3 ? "4+" : character.Languages)
                </GuessChip>

                @if (character.Affiliations.Count > 0)
                {
                    @foreach (var affiliation in character.Affiliations)
                    {
                        <GuessChip Result="guess.Affiliation">
                            @affiliation
                        </GuessChip>

                    }
                }
                else
                {
                    <GuessChip Result="guess.Affiliation">
                        Affiliations: None
                    </GuessChip>
                }


                <GuessChip Result="guess.Joined">
                    <span class="chip-labels">Joined on</span> Day @character.JoinDayNumber
                </GuessChip>

            </div>
        </div>
    }

</div>

<style>
    .guess-card,
    .placeholder-card {
        padding: 1rem;

        background:
            linear-gradient(to top left, var(--panel-strong), var(--panel));

        backdrop-filter: blur(1rem);

        border-radius: .75rem;
        border: .125rem solid var(--panel-edge);
        box-shadow: inset 0 0 0 .0625rem var(--black);
        transition:
            border-color 160ms ease;
    }

    .guess-card:hover {
        border-color: var(--line-strong);
    }

    .placeholder-card {
        opacity: 0.5;
        background:
            linear-gradient(to top left, var(--surface), hsla(var(--primary-hsl), 0.08));
        border-color: var(--line);
    }

    .guess-card-grid,
    .placeholder-card-grid {
        display: grid;

        grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));

        gap: .5rem;

        margin-top: 1rem;
    }

    .guess-card-grid .mud-chip,
    .placeholder-card-grid .mud-chip {
        width: 100%;
    }

    .guess-avatar,
    .placeholder-avatar {
        width: 5rem;
        height: 5rem;

        image-rendering: pixelated;
        background: var(--surface-muted);
        border: .0625rem solid var(--line);
    }

    .placeholder-avatar {
        opacity: .4;
    }

    .guess-name {
        font-size: 1.1rem;
        font-weight: 500;
        letter-spacing: .02em;
    }

    .placeholder-text {
        color: rgba(255, 255, 255, .25);
    }

    .placeholder-chip {
        width: 6rem;
        margin: 0 auto;

        opacity: .25;
        pointer-events: none;
    }
</style>


@code {
    [Parameter]
    public IReadOnlyList<GuessResult> Guesses { get; set; } = null!;

    [Parameter]
    public int MaxGuesses { get; set; } = 6;

    private Dictionary<int, Character> CharactersById { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        CharactersById = (await CharacterStore.GetCharactersAsync()).ToDictionary(character => character.Id);
    }

    private static string DisplayList(IEnumerable<string> values)
    {
        return values.Any()
            ? string.Join(", ", values)
            : "None";
    }

    private Character? GetCharacter(int id)
    {
        return CharactersById.GetValueOrDefault(id);
    }

    private static string FormatSpecies(Character character) =>
        character.Species.Contains("Human")
            ? "Human"
            : character.Species.Contains("Unknown")
                ? "Species: Unknown"
                : "Not Human";
}
