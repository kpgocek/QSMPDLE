@using MudBlazor
@using QSMPDLE.Web.Features.Characters.DTOs
@using QSMPDLE.Web.Features.Gameplay.Models
@using QSMPDLE.Web.Features.Gameplay.Services
@using QSMPDLE.Web.Features.Gameplay.Stores
@using QSMPDLE.Web.Models

@inject IJSRuntime JS
@inject IGameService GameService
@inject IGameStateManager GameStateManager
@inject IGameplayOrchestrator GameplayOrchestrator
@inject IPlayerStatsStore PlayerStatsStore

<MudStack AlignItems="AlignItems.Center" Spacing="4" Class="w-100 gameplay">

    <MudPaper Class="ma-4 image-wrapper" Elevation="0">
        <CharacterPortrait Character="currentGame.Target" GuessesMade="currentGame.Guesses.Count" IsGuessed="IsGameWon"
                           IsFailed="IsGameLost" />
    </MudPaper>
    @if (IsGameOver)
    {
        <div class="answer-reveal @(IsGameWon ? "success" : "failure")">
            <h3>@currentGame.Target.Name</h3>
        </div>
    }

    @if (EndlessMode)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Default" StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="StartNewGame">
            New Character
        </MudButton>
    }

    <CharacterSelector @bind-Value="GuessedCharacter" OnGuessConfirmed="Guess" IsGuessed="IsGameOver" />

    <div class="guess-table-container">
        <GuessTable Guesses="currentGame?.Guesses" />
        <GuessCards Guesses="currentGame?.Guesses" />
    </div>
</MudStack>

<style>
    .gameplay {
        position: relative;
    }

    .gameplay::before {
        content: "";
        position: absolute;
        inset: 0;

        background: radial-gradient(ellipse at center,
                rgba(0, 140, 255, .12),
                transparent 70%);

        z-index: -1;
    }

    .guess-table-container {
        width: 100%;
        max-width: 1200px;
    }

    .answer-reveal {
        text-align: center;
    }

    .answer-reveal h3 {
        font-weight: 700;
    }

    .success {
        color: var(--correct);
    }

    .failure {
        color: var(--wrong);
    }
</style>

@code {
    [Parameter]
    public bool EndlessMode { get; set; }

    [Parameter]
    public EventCallback<int> DayNumberChanged { get; set; }

    [Parameter]
    public EventCallback<bool> GameEnded { get; set; }

    [Parameter]
    public EventCallback<List<Guess>> VictoryAnnounced { get; set; }
    [Parameter]
    public EventCallback<Character> FailureAnnounced { get; set; }

    [Parameter]
    public EventCallback<PlayerStats> StatsUpdated { get; set; }

    private Game currentGame = null!;
    private CharacterLookup? GuessedCharacter;
    private GameState state = new();

    private bool IsGameWon;
    private bool IsGameLost;

    private bool IsGameOver => IsGameWon || IsGameLost;

    private string GameKey => $"qsmpdle-daily-{currentGame.DayNumber}";

    protected override async Task OnInitializedAsync()
    {
        currentGame = EndlessMode
            ? await GameService.StartEndlessAsync()
            : await GameService.StartDailyAsync();

        await DayNumberChanged.InvokeAsync(currentGame.DayNumber);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        // Load game state from local storage (JS interop only allowed here)
        state = await GameStateManager.LoadOrCreateAsync(EndlessMode, GameKey);

        // Restore previous guesses from saved state
        foreach (var characterId in state.GuessesMade)
        {
            GameService.SubmitGuess(currentGame, characterId);
        }

        IsGameWon = state.IsCompleted;
        IsGameLost = state.IsFailed;

        StateHasChanged();
    }

    public async Task Guess()
    {
        if (IsGameWon || GuessedCharacter is null)
            return;

        // Process guess through orchestrator
        var result = GameplayOrchestrator.ProcessGuess(currentGame, GuessedCharacter.Id, state);

        // Duplicate guess check
        if (result.LatestGuess is null)
        {
            GuessedCharacter = null;
            return;
        }

        IsGameWon = result.IsGameWon;
        IsGameLost = result.IsGameLost;

        // Handle win
        if (result.IsGameWon)
        {
            if (!EndlessMode && !state.StatsRecorded)
            {
                var stats = await GameplayOrchestrator.RecordWinAsync(currentGame, EndlessMode);
                await StatsUpdated.InvokeAsync(stats);
                state.StatsRecorded = true;
            }

            if (!state.VictoryPopupShown)
            {
                await VictoryAnnounced.InvokeAsync(currentGame.Guesses);
                await JS.InvokeVoidAsync("scrollToTop");
                state.VictoryPopupShown = true;
            }

            await GameEnded.InvokeAsync(true);
        }
        // Handle loss
        else if (result.IsGameLost)
        {
            if (!EndlessMode && !state.StatsRecorded)
            {
                var stats = await GameplayOrchestrator.RecordLossAsync();
                await StatsUpdated.InvokeAsync(stats);
                state.StatsRecorded = true;
            }

            if (!state.FailurePopupShown)
            {
                await FailureAnnounced.InvokeAsync(currentGame.Target);
                await JS.InvokeVoidAsync("scrollToTop");
                state.FailurePopupShown = true;
            }

            await GameEnded.InvokeAsync(false);
        }

        // Save state to local storage
        await GameStateManager.SaveAsync(state, EndlessMode, GameKey);

        GuessedCharacter = null;
    }

    private async Task StartNewGame()
    {
        state = new GameState();

        IsGameLost = false;
        IsGameWon = false;

        GuessedCharacter = null;

        currentGame = await GameService.StartEndlessAsync();

        StateHasChanged();
    }
}
