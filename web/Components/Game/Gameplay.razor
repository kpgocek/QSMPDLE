@using MudBlazor
@using QSMPDLE.Web.Components.Game.Modules
@using QSMPDLE.Web.Components.UX
@using QSMPDLE.Web.Features.Communication.GameEvents
@using QSMPDLE.Web.Features.Gameplay.Models
@using QSMPDLE.Web.Features.Gameplay.Services
@using QSMPDLE.Web.Features.Statistics.Services

@inject IGameStateManager GameStateManager
@inject IStatisticsService StatisticsService

<MudStack AlignItems="AlignItems.Center" Spacing="4" Class="w-100 gameplay">
    @if (!IsGameLoaded)
    {

        <MudPaper Style="padding: .5rem; border: 0.125rem solid var(--line-strong); box-shadow: var(--soft-shadow); border-radius: .75rem;"
                  Elevation="0" Height="min(20rem, 82vw);" Width="min(20rem, 82vw);">
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="100%" Width="100%" />
        </MudPaper>

        <div class="answer-reveal" >
            <h3><MudSkeleton SkeletonType="SkeletonType.Text" Width="4rem" Height="2.5rem" /></h3>
        </div>

        @if (GameMode == GameMode.Practice)
        {
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="min(16rem, calc(100vw - 2rem))" Height="3rem" />
        }

        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="min(24.25rem, calc(100vw - 2rem))" Height="3rem" />
    }
    else
    {
        <CharacterPortrait 
            IconUrl="@(GameStateManager.GameState?.Game.PortraitUrl ?? string.Empty)" 
            GuessesMade="@(GameStateManager.GameState?.GuessesMade.Count ?? 0)" 
            IsGuessed="@(GameStateManager.GameState?.IsWon ?? false)"
            IsFailed="@(GameStateManager.GameState?.IsLost ?? false)" />
        @if (GameStateManager.GameState?.IsFinished ?? false)
        {
            <div class="answer-reveal @(GameStateManager.GameState.IsWon ? "success" : "failure")">
                <h3>@TargetName</h3>
            </div>
        }
        else
        {
            <CharacterSelector @bind-Value="GuessedCharacter" OnGuessConfirmed="Guess" IsGuessed="@(GameStateManager.GameState?.IsFinished ?? false)" IsBusy="@_isGuessing" />
        }

        @if (GameMode == GameMode.Practice)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Default" StartIcon="@Icons.Material.Filled.Refresh" OnClick="NewPractice">
                New Character
            </MudButton>
        }

        }

    <div class="guess-table-container">
        <GuessTable Guesses="@(GameStateManager.GameState?.GuessesMade ?? [])" />
        <GuessCards Guesses="@(GameStateManager.GameState?.GuessesMade ?? [])" />
    </div>

</MudStack>



@if (!(GameStateManager.GameState?.SeenPopup ?? false) && (GameStateManager.GameState?.IsWon ?? false))
{
    <VictoryDialog GameState="@GameStateManager.GameState" OnClose="ClosePopups" />
}

@if (!(GameStateManager.GameState?.SeenPopup ?? false) && (GameStateManager.GameState?.IsLost ?? false))
{
    <FailureDialog GameState="@GameStateManager.GameState" OnClose="ClosePopups" />
}


<style>
    .gameplay {
        position: relative;
        margin-top: 1.25rem;
    }

    .gameplay::before {
        content: "";
        position: absolute;
        inset: 0;

        background: radial-gradient(ellipse at center, var(--surface), transparent 70%);

        z-index: -1;
    }

    .guess-table-container {
        width: 100%;
        max-width: 75rem;
    }

    .answer-reveal {
        text-align: center;
    }

    .answer-reveal h3 {
        font-weight: 700;
    }

    .success {
        color: var(--correct);
    }

    .failure {
        color: var(--wrong);
    }
</style>

@code {
    [Parameter]
    public GameMode GameMode { get; set; }

    [Parameter]
    public int? ArchiveGameNumber { get; set; }

    [Parameter]
    public EventCallback<GameState> GameStateChanged { get; set; }

    [Parameter] 
    public EventCallback GameLoaded { get; set; }

    private CharacterLookup? GuessedCharacter;
    private bool IsGameLoaded = false;
    private bool _isGuessing;
    private string TargetName = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await StartNewGameAsync();
        }
    }

    public async Task Guess(CharacterLookup? _ = null)
    {
        if (_isGuessing || GameStateManager.GameState is null || GameStateManager.GameState.IsFinished || GuessedCharacter is null)
            return;

        _isGuessing = true;
        var guessedCharacterId = GuessedCharacter.Id;
        GuessedCharacter = null;

        try
        {
            var result = await GameStateManager.MakeGuessAsync(guessedCharacterId);

            if (result is null)
                return;

            if (GameStateManager.GameState.IsFinished)
            {
                TargetName = await GameStateManager.GetTargetName();
            }

            await GameStateChanged.InvokeAsync(GameStateManager.GameState);
            await InvokeAsync(StateHasChanged);

            if (GameStateManager.GameState.GuessesMade.Count == 1)
            {
                await StatisticsService.RecordGameStartedAsync(new GameStartedEvent
                {
                    Timestamp = DateTime.UtcNow,
                    DayNumber = GameStateManager.GameState.Game.DayNumber,
                    PlayerId = GameStateManager.GameState.PlayerId,
                    GameId = GameStateManager.GameState.GameId,
                    GameMode = GameMode,
                    TargetCharacterId = GameStateManager.GameState.Game.TargetId,
                });
            }

            await StatisticsService.RecordGuessMadeAsync(new GuessMadeEvent
            {
                Timestamp = DateTime.UtcNow,
                PlayerId = GameStateManager.GameState.PlayerId,
                GameId = GameStateManager.GameState.GameId,
                GuessedCharacterId = guessedCharacterId,
            });

            await RecordFinishedGameStatsIfNeededAsync();
        }
        finally
        {
            _isGuessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task StartNewGameAsync()
    {
        var loadingResult = await GameStateManager.LoadOrCreateAsync(GameMode, GameMode == GameMode.Archive ? ArchiveGameNumber : null);

        if (loadingResult == LoadGameResult.Failed)
        {
            throw new InvalidOperationException("Cannot initiate new game.");
        }

        // Notify parent component of the updated game state
        await GameStateChanged.InvokeAsync(GameStateManager.GameState);

        if (GameStateManager.GameState.IsFinished)
        {
            TargetName = await GameStateManager.GetTargetName();
        }

        IsGameLoaded = true;
        await GameLoaded.InvokeAsync();

        await InvokeAsync(StateHasChanged);

        await RecordFinishedGameStatsIfNeededAsync();
    }

    private async Task NewPractice()
    {
        await GameStateManager.StartNewPracticeGameAsync();
        TargetName = string.Empty;
        await GameStateChanged.InvokeAsync(GameStateManager.GameState);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ClosePopups()
    {
        if (GameStateManager.GameState is null)
            return;

        await GameStateManager.MarkPopupAsSeenAsync();

        await InvokeAsync(StateHasChanged);
    }

    private async Task RecordFinishedGameStatsIfNeededAsync()
    {
        if (GameStateManager.GameState is not { IsFinished: true, StatsRecorded: false })
            return;

        await StatisticsService.RecordGameFinishedAsync(new GameFinishedEvent
        {
            Timestamp = DateTime.UtcNow,
            GameMode = GameMode,
            DayNumber = GameStateManager.GameState.Game.DayNumber,
            PlayerId = GameStateManager.GameState.PlayerId,
            GameId = GameStateManager.GameState.GameId,
            GuessCount = GameStateManager.GameState.GuessesMade.Count,
            IsWon = GameStateManager.GameState.IsWon,
        });

        await GameStateManager.MarkStatsRecordedAsync();
    }
}
