@using MudBlazor
@using QSMPDLE.Web.Features.Gameplay.Models
@using QSMPDLE.Web.Features.Sharing.Services
@using QSMPDLE.Web.Features.Sharing.Builders
@inject IJSRuntime JS
@inject IShareService ShareService
@inject IShareTextBuilder ShareTextBuilder

<div class="failure-overlay">
    <div class="failure-modal">

        <h2>Welp!</h2>
        @if (DayNumber is not null)
        {
            <p>
                You've reached the limit trying to guess character #@DayNumber.
            </p>
        }
        else
        {
            <p>
                You've reached the maximum number of guesses. Try again?
            </p>
        }

        <div class="buttons">
            <MudMenu Icon="@Icons.Material.Filled.Share" Variant="Variant.Filled" Color="Color.Primary">

                <MudMenuItem OnClick="Share">
                    <MudIcon Icon="@Icons.Material.Filled.Share" />
                    Challenge Others
                </MudMenuItem>

                <MudMenuItem OnClick="CopyShareText">
                    <MudIcon Icon="@Icons.Material.Filled.ContentCopy" />
                    Copy
                </MudMenuItem>

                <MudMenuItem Href="@BuildXLink()" Target="_blank">
                    <MudIcon Icon="@Icons.Custom.Brands.Twitter" />
                    X
                </MudMenuItem>

                <MudMenuItem Href="@BuildTelegramLink()" Target="_blank">
                    <MudIcon Icon="@Icons.Custom.Brands.Telegram" />
                    Telegram
                </MudMenuItem>

                <MudMenuItem Href="@BuildRedditLink()" Target="_blank">
                    <MudIcon Icon="@Icons.Custom.Brands.Reddit" />
                    Reddit
                </MudMenuItem>

            </MudMenu>

            <MudButton OnClick="Close">
                Close
            </MudButton>
        </div>

    </div>
</div>

<style>
    .failure-overlay {
        position: fixed;
        inset: 0;

        background: rgba(0, 0, 0, .75);

        display: flex;
        justify-content: center;
        align-items: center;

        z-index: 10000;
    }

    .failure-modal {
        background: var(--primary-black);
        padding: 2rem;
        border-radius: .5rem;
        min-width: 320px;
    }

    .buttons {
        display: flex;
        gap: 1rem;
        justify-content: end;
        margin-top: 1rem;
    }
</style>

@code {
    [Parameter] public int? DayNumber { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public PlayerStats? Stats { get; set; } = null!;
    private async Task Share()
    {
        ArgumentNullException.ThrowIfNull(DayNumber);

        var text = ShareTextBuilder.BuildDailyChallenge(
            DayNumber.Value);

        await ShareService.ShareAsync(text);
    }

    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }

    private string BuildShareText()
    {
        ArgumentNullException.ThrowIfNull(DayNumber);

        return ShareTextBuilder.BuildDailyChallenge(DayNumber.Value);
    }

    private async Task CopyShareText()
    {
        await ShareService.ShareAsync(BuildShareText());
    }

    private string BuildXLink()
    {
        return $"https://twitter.com/intent/tweet?text={Uri.EscapeDataString(BuildShareText())}";
    }

    private string BuildTelegramLink()
    {
        return $"https://t.me/share/url?text={Uri.EscapeDataString(BuildShareText())}";
    }

    private string BuildRedditLink()
    {
        return $"https://reddit.com/submit?title={Uri.EscapeDataString(BuildShareText())}";
    }
}
